  m_Name: 
  m_EditorClassIdentifier: UnityEngine.UI::UnityEngine.UI.Text
  m_Material: {fileID: 0}
  m_Color: {r: 0.95, g: 0.97, b: 1, a: 1}
  m_RaycastTarget: 0
